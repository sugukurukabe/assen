# DATABASE_URL: アプリ/テストが使う実行時接続。RLSを実効性あるものにするため、superuser/BYPASSRLSを持たない
# 制限ロール（assen_app）で接続する。本番はCloud SQLの同等ロールのURLに差し替える
# DATABASE_URL: runtime connection used by the app/tests. For RLS to actually take effect, connects as a
# restricted role with no superuser/BYPASSRLS (assen_app). Replace with the Cloud SQL equivalent role's URL in production
# DATABASE_URL: koneksi runtime yang dipakai app/test. Agar RLS benar-benar berlaku, terhubung sebagai role
# terbatas tanpa superuser/BYPASSRLS (assen_app). Ganti dengan URL role setara di Cloud SQL saat produksi
DATABASE_URL=postgres://assen_app:assen_app_local_dev_only@localhost:55432/assen

# MIGRATION_DATABASE_URL: db:migrate専用（テーブル作成・RLS強制・GRANT付与にはsuperuser相当の権限が必要）。
# 未設定ならDATABASE_URLにフォールバックするが、ロール分離済みのローカル開発では必ず設定すること
# MIGRATION_DATABASE_URL: dedicated to db:migrate (creating tables, forcing RLS, and granting privileges needs
# superuser-equivalent rights). Falls back to DATABASE_URL when unset, but must be set once roles are separated locally
# MIGRATION_DATABASE_URL: khusus untuk db:migrate (membuat tabel, memaksakan RLS, dan memberi grant membutuhkan
# hak setara superuser). Fallback ke DATABASE_URL jika tidak diatur, tapi harus diatur setelah role dipisahkan secara lokal
MIGRATION_DATABASE_URL=postgres://assen:assen_local_dev_only@localhost:55432/assen

# STORAGE_ENDPOINT: MinIO(ローカル)またはGCSのエンドポイント
# STORAGE_ENDPOINT: MinIO (local) or GCS endpoint
# STORAGE_ENDPOINT: endpoint MinIO (lokal) atau GCS
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=assen
STORAGE_SECRET_KEY=assen_local_dev_only
STORAGE_BUCKET=assen-documents

# PII_ENCRYPTION_KEY: 32byte(base64)のローカル開発用鍵。本番はKMSに置き換える
# PII_ENCRYPTION_KEY: 32-byte base64 local dev key. Replace with KMS in production.
# PII_ENCRYPTION_KEY: kunci dev lokal base64 32-byte. Ganti dengan KMS di produksi.
PII_ENCRYPTION_KEY=

# PORT: MCPサーバーのポート
PORT=8080

# AUTH_MODE: local_fixed_token（開発） | oauth（本番）
AUTH_MODE=local_fixed_token
AUTH_LOCAL_TOKEN=

# OAUTH_*: AUTH_MODE=oauth時のみ使用。JWTのissuer/audienceを検証し、token passthroughを禁止する
# OAUTH_*: used only when AUTH_MODE=oauth. Validates the JWT issuer/audience; no token passthrough
# OAUTH_*: hanya dipakai saat AUTH_MODE=oauth. Memvalidasi issuer/audience JWT; tidak boleh token passthrough
OAUTH_ISSUER=
OAUTH_AUDIENCE=
OAUTH_JWKS_URI=
# OAUTH_ROLE_CLAIM/OAUTH_TENANT_CLAIM: role/tenantIdを載せるJWTクレーム名（IdP側のカスタムクレームに合わせる）
OAUTH_ROLE_CLAIM=role
OAUTH_TENANT_CLAIM=tenant_id

# CORS_ALLOWED_ORIGINS: /mcpへのブラウザ発cross-originアクセスを許可するorigin（カンマ区切り、"*"で全許可）。既定は空＝無効
# CORS_ALLOWED_ORIGINS: origins allowed to call /mcp from a browser (comma-separated, "*" allows all). Default empty = disabled
CORS_ALLOWED_ORIGINS=

# SERVER_CARD_*: /.well-known/mcp.jsonに載せるrepository/contact URL。未設定ならnullを返す（URLを捏造しない）
# SERVER_CARD_*: repository/contact URLs published in /.well-known/mcp.json. Returns null when unset (never fabricates a URL)
SERVER_CARD_REPOSITORY_URL=
SERVER_CARD_CONTACT_URL=

# LLM_API_KEY: 抽出（fact_assertions生成）に使うLLMのAPIキー
LLM_API_KEY=

# NODE_ENV: development | test | production。productionではAUTH_MODE=oauth必須・PII_ENCRYPTION_KEY必須になる
# NODE_ENV: development | test | production. In production, AUTH_MODE=oauth and PII_ENCRYPTION_KEY are required
# NODE_ENV: development | test | production. Di production, AUTH_MODE=oauth dan PII_ENCRYPTION_KEY wajib
NODE_ENV=development

# MAX_REQUEST_BODY_BYTES: HTTPリクエストボディの上限（バイト、既定20MB）
# MAX_REQUEST_BODY_BYTES: max HTTP request body size in bytes (default 20MB)
# MAX_REQUEST_BODY_BYTES: batas ukuran body permintaan HTTP dalam byte (default 20MB)
MAX_REQUEST_BODY_BYTES=20971520

# DB_POOL_*: pgのPool設定（Cloud SQL接続数上限に合わせて調整する）
# DB_POOL_*: pg Pool tuning (adjust to respect Cloud SQL connection limits)
# DB_POOL_*: penyesuaian Pool pg (sesuaikan dengan batas koneksi Cloud SQL)
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=5000
